      "url": "/resident/invite-visitor",
      "icons": [{ "src": "/android-chrome-192x192.png", "sizes": "192x192" }]
    },
    {
      "name": "Verify Visitor",
      "short_name": "Verify",
      "url": "/security/verify-visitor",
      "icons": [{ "src": "/android-chrome-192x192.png", "sizes": "192x192" }]
    }
  ]
}
