NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ESTATE_APP_URL=http://localhost:3000
NEXT_PUBLIC_ENABLE_LOCAL_DEMO=true
NEXT_PUBLIC_APPWRITE_PROJECT_ID=lbsview-estate
NEXT_PUBLIC_APPWRITE_PROJECT_NAME=LBS View Estate
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://fra.cloud.appwrite.io/v1
APPWRITE_ENDPOINT=https://fra.cloud.appwrite.io/v1
APPWRITE_DATABASE_ID=lbsview_estate

# Server-only Appwrite API key with Auth Users and TablesDB database/table/row permissions.
# Never expose this as a NEXT_PUBLIC_* value.
# Appwrite reserves APPWRITE_* injected variables for sites, so use this neutral key.
# CORSO_APPWRITE_API_KEY=your-appwrite-server-api-key

# Resend transactional email (welcome emails / password resets / notifications).
# Create the key at https://resend.com/api-keys with "Sending access".
# RESEND_API_KEY=re_your_resend_api_key
# CORSO_EMAIL_FROM=Corso <notifications@corso.ng>

# Monnify payment link integration.
# Use https://sandbox.monnify.com for testing and https://api.monnify.com for production.
MONNIFY_API_KEY=your_monnify_api_key
MONNIFY_SECRET_KEY=your_monnify_secret_key
MONNIFY_CONTRACT_CODE=your_contract_code
MONNIFY_BASE_URL=https://sandbox.monnify.com

# Optional legacy Supabase backend values.
# Leave these unset for the Appwrite-hosted local demo deployment.
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# SUPABASE_SECRET_KEY=your-server-only-supabase-secret-key
